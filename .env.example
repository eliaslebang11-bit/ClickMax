# === BACKEND (Private Secrets - Never expose to Frontend) ===
# Set these in your Render or Server-side environment dashboard.
# DO NOT include these in your mobile app build.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=your-secure-jwt-secret
PORT=3000
NODE_ENV=production

# Cloudflare Storage Secrets (Backend Only)
CLOUDFLARE_R2_ACCOUNT_ID=your-r2-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key
CLOUDFLARE_R2_BUCKET_NAME=your-r2-bucket
VITE_CLOUDFLARE_R2_PUBLIC_DOMAIN=your-bucket-public-url.r2.dev

# Cloudflare Stream Secrets (Backend Only)
CLOUDFLARE_ACCOUNT_ID=your-cf-account-id
CLOUDFLARE_API_TOKEN=your-cf-stream-token
CLOUDFLARE_EMAIL=your-cf-email
CLOUDFLARE_API_KEY=your-cf-global-key
